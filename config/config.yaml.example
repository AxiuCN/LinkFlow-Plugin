# ==============================================================
# Bilibili-Plugin 配置文件
# 请将此文件复制为 config.yaml 并根据需要修改
# ==============================================================

# B站账号登录（apps/login.js）
login:
  # 扫码登录轮询超时（秒）
  pollTimeout: 180

# B站激励计划（apps/incentive.js）
incentive:
  # ---------- 全局开关 ----------
  enabled: true

  # ===== 直播激励领取 =====
  # ---------- 直播领取 cron ----------
  liveCron: '0 0 1 * * ?'
  # ---------- 直播截止时间（秒），0=不限 ----------
  claimDeadline: 40
  # ---------- 直播领取设置 ----------
  claim:
    # 并发领取线程数（同时发送请求的 worker 数量，建议 2-5）
    threadCount: 2
    # 单个 worker 最大重试次数
    maxRetry: 30
    # 重试间隔（秒）
    retryInterval: 1.0
    # 单次请求超时（秒）
    timeout: 10

  # ===== 看播激励领取 =====
  # ---------- 看播领取 cron ----------
  watchCron: '0 30 0 * * ?'
  # ---------- 看播截止时间（秒），0=不限 ----------
  watchDeadline: 12
  # ---------- 看播领取设置 ----------
  watch:
    # 并发领取线程数（同时发送请求的 worker 数量）
    threadCount: 1
    # 单个 worker 最大重试次数
    maxRetry: 30
    # 重试间隔（秒）
    retryInterval: 1.0
    # 单次请求超时（秒）
    timeout: 10

  # ===== 每日任务激励兜底 =====
  # ---------- 兜底领取 cron ----------
  fallbackCron: '0 55 23 * * ?'
  # ---------- 每日任务链接（4个，主人配置）----------
  dailyTaskLinks:
    - ''
    - ''
    - ''
    - ''

# B站直播推送（apps/livepush.js）
livePush:
  # 是否启用
  enabled: true
  # cron 表达式（秒 分 时 日 月 周）
  cron: '10 * * * * *'
  # 是否推送下播消息
  endPush: true
  # 是否使用合并转发推送
  forward: false
  # 标题变更时是否再次推送
  rePush: false
  # 群间推送间隔（秒）
  sleep: 0

# ==============================================================
# LinkFlow-Plugin 个人激励配置示例
# 文件名为 {QQ}.yaml，存储于 config/incentive_config/
# ==============================================================
# 通过 #激励创建配置 生成
# 使用 #激励添加 <序号> <链接> 填入活动链接
# 每日定时自动领取非空槽位内的奖励
#
# notifyGroup : 通知群号（0=不通知）
# links       : 固定 20 个槽位（1-10 直播，11-20 看播），填入含 task_id 的活动链接
# ==============================================================

notifyGroup: ${notifyGroup}
links:
  # ---- 直播（1-10）----
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  # ---- 看播（11-20）----
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
